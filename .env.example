# kd-galaxy 适配器测试环境变量
# 复制此文件为 .env 并填入真实值以进行集成测试
# 注意：.env 文件不应提交到 Git！

# =============================================================================
# 基础配置
# =============================================================================

# API 基础地址
KD_GALAXY_BASE_URL=https://api.example.com

# 环境标识 (production/sandbox/development)
KD_GALAXY_ENVIRONMENT=sandbox

# =============================================================================
# 认证配置 - standard 接口
# =============================================================================

# OAuth2 / API Key 认证
KD_GALAXY_CLIENT_ID=your-client-id
KD_GALAXY_CLIENT_SECRET=your-client-secret
KD_GALAXY_TOKEN_URL=https://api.example.com/oauth/token

# =============================================================================
# 认证配置 - enterprise 接口（如启用双接口）
# =============================================================================

# HMAC / 签名认证
KD_GALAXY_APP_KEY=your-app-key
KD_GALAXY_APP_SECRET=your-app-secret
KD_GALAXY_CUSTOMER_ID=your-customer-id

# =============================================================================
# 测试配置
# =============================================================================

# 是否录制请求/响应 (true/false)
RECORD_HTTP_TRAFFIC=true

# 测试数据目录
TEST_DATA_DIR=tests/data

# 请求超时时间（秒）
REQUEST_TIMEOUT=30

# 是否使用真实 API 进行测试 (true=真实API, false=Mock)
USE_REAL_API=false