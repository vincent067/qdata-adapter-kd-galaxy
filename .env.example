# kd-galaxy 适配器测试环境变量
# 复制此文件为 .env 并填入真实值以进行集成测试
# 注意：.env 文件不应提交到 Git！

# =============================================================================
# 基础配置
# =============================================================================

# API 基础地址（金蝶云星空格式）
# 格式: https://api.example.com/k3cloud/
# 注意：必须以 /k3cloud/ 结尾
KD_GALAXY_BASE_URL=https://api.example.com/k3cloud/

# 环境标识 (production/sandbox/development)
KD_GALAXY_ENVIRONMENT=sandbox

# =============================================================================
# 认证配置 - 金蝶云星空 Cookie-Based 认证
# =============================================================================

# 账套ID (data_center_id)
# 登录第三方授权系统时使用的账套ID
KD_GALAXY_ACCT_ID=your-data-center-id

# 用户名
# 第三方授权系统的登录用户名
KD_GALAXY_USERNAME=administrator

# 应用ID
# 第三方授权系统的应用ID
KD_GALAXY_APP_ID=your-app-id

# 应用密钥
# 第三方授权系统的应用密钥
KD_GALAXY_APP_SECRET=your-app-secret

# 语言ID（可选，默认 2052 简体中文）
KD_GALAXY_LCID=2052

# =============================================================================
# 测试配置
# =============================================================================

# 是否录制请求/响应 (true/false)
RECORD_HTTP_TRAFFIC=false

# 测试数据目录
TEST_DATA_DIR=tests/data

# 请求超时时间（秒）
REQUEST_TIMEOUT=300

# 是否使用真实 API 进行测试 (true=真实API, false=Mock)
USE_REAL_API=false
